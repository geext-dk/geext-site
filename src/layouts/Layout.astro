---
interface Props {
	title?: string;
}

const { title = "Denis Karpovskii" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="site-name" href="/">Denis Karpovskii</a>
				<nav class="site-nav" aria-label="Primary navigation">
					<a href="/photography/">Photography</a>
					<a href="/#projects">Projects</a>
				</nav>
			</header>

			<slot />

			<footer class="site-footer">
				<p>&copy; Denis Karpovskii</p>
			</footer>
		</div>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: #fbfaf6;
		color: #111;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	a {
		color: inherit;
	}

	a:focus-visible {
		outline: 2px solid #111;
		outline-offset: 4px;
	}

	.site-shell {
		display: grid;
		grid-template-rows: auto 1fr auto;
		min-height: 100vh;
	}

	.site-header,
	.site-footer {
		width: min(100% - 2rem, 76rem);
		margin: 0 auto;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 4.25rem;
		padding: 1rem 0;
	}

	.site-name {
		color: #111;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0;
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: end;
		gap: 0.85rem 1.25rem;
	}

	.site-nav a {
		color: #111;
		font-size: 0.95rem;
		line-height: 1.4;
		text-decoration: none;
		text-decoration-line: none;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	.site-nav a:hover,
	.site-nav a:focus-visible {
		text-decoration: underline;
		text-decoration-line: underline;
	}

	.site-footer {
		padding: 2rem 0 2.5rem;
		color: #76716a;
	}

	.site-footer p {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.5;
	}

	@media (max-width: 700px) {
		.site-header,
		.site-footer {
			width: min(100% - 1.25rem, 76rem);
		}

		.site-header {
			min-height: 3.75rem;
		}
	}
</style>
