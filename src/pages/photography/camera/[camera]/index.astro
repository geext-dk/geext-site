---
import Layout from "../../../../layouts/Layout.astro";
import PhotographyPage from "../../../../components/PhotographyPage.astro";
import { cameras, films, paginate, photoCountLabel, photosForFacet } from "../../../../lib/photos";

export function getStaticPaths() {
	return cameras.map((camera) => ({
		params: { camera: camera.slug },
		props: { camera },
	}));
}

const { camera } = Astro.props;
const page = paginate(photosForFacet("camera", camera.slug), 1);
---

<Layout>
	<PhotographyPage
		title={camera.name}
		subtitle={`${photoCountLabel(page.totalPhotos)} shot with this camera`}
		page={page}
		basePath={`/photography/camera/${camera.slug}`}
		cameras={cameras}
		films={films}
	/>
</Layout>
