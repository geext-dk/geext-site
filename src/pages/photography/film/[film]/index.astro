---
import Layout from "../../../../layouts/Layout.astro";
import PhotographyPage from "../../../../components/PhotographyPage.astro";
import { cameras, films, paginate, photoCountLabel, photosForFacet } from "../../../../lib/photos";

export function getStaticPaths() {
	return films.map((film) => ({
		params: { film: film.slug },
		props: { film },
	}));
}

const { film } = Astro.props;
const page = paginate(photosForFacet("film", film.slug), 1);
---

<Layout>
	<PhotographyPage
		title={film.name}
		subtitle={`${photoCountLabel(page.totalPhotos)} shot on this film`}
		page={page}
		basePath={`/photography/film/${film.slug}`}
		cameras={cameras}
		films={films}
	/>
</Layout>
