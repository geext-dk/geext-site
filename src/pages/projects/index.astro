---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../lib/projects";

const getProjectActionLabel = (linkType: "appstore" | "simple" | undefined) =>
	linkType === "appstore" ? "Download on the App Store" : "Learn more";
---

<Layout title="Projects | Denis Karpovskii">
	<main class="projects-page">
		<header class="page-header">
			<h1>Projects</h1>
			<p>Selected work and experiments.</p>
		</header>

		<div class="project-sections">
			{projects.map((project) => (
				<section class="project-section" aria-labelledby={`project-${project.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>
					<span class="project-image">
						<img src={project.image} alt="" loading="lazy" decoding="async" />
					</span>
					<div class="project-copy">
						<h2 id={`project-${project.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>{project.title}</h2>
						<p>{project.description}</p>
						<div class="project-actions">
							{project.url ? (
								<a
									class:list={["project-action", { "project-action-appstore": project.linkType === "appstore" }]}
									href={project.url}
									aria-label={`${getProjectActionLabel(project.linkType)}: ${project.title}`}
								>
									{project.linkType === "appstore" ? (
										<img src="/download-on-appstore-icon.svg" alt="" width="120" height="40" loading="lazy" decoding="async" />
									) : (
										getProjectActionLabel(project.linkType)
									)}
								</a>
							) : null}
							{project.sourceUrl ? (
								<a class="project-action" href={project.sourceUrl} target="_blank" rel="noreferrer">Source code</a>
							) : null}
						</div>
					</div>
				</section>
			))}
		</div>
	</main>
</Layout>

<style>
	.projects-page {
		width: min(100% - 2rem, 76rem);
		margin: 0 auto;
		padding: 2rem 0 4rem;
	}

	.page-header {
		display: grid;
		gap: 0.45rem;
		margin-bottom: 2rem;
	}

	h1,
	h2,
	p {
		margin: 0;
	}

	h1 {
		color: #111;
		font-size: clamp(2rem, 4vw, 4rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1;
	}

	.page-header p,
	.project-copy p {
		color: #555;
		font-size: 1rem;
		line-height: 1.5;
	}

	.project-sections {
		display: grid;
		gap: 1.5rem;
	}

	.project-section {
		display: grid;
		place-items: center;
		gap: 1rem;
		min-height: min(32rem, calc(100vh - 10rem));
		padding: 4rem 1.5rem;
		text-align: center;
	}

	.project-section + .project-section {
		border-top: 1px solid #ddd8ce;
	}

	.project-image {
		display: grid;
		place-items: center;
		width: clamp(9rem, 24vw, 15rem);
		aspect-ratio: 1;
		border-radius: 50%;
		background: #ece8df;
		overflow: hidden;
	}

	.project-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-copy {
		display: grid;
		justify-items: center;
		gap: 0.6rem;
		max-width: 42rem;
	}

	h2 {
		color: #111;
		font-size: clamp(1.5rem, 3vw, 2.4rem);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.05;
	}

	.project-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 0.25rem;
	}

	.project-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.35rem;
		padding: 0 0.9rem;
		border: 1px solid #111;
		border-radius: 999px;
		color: #111;
		font-size: 0.95rem;
		text-decoration: none;
		transition:
			background 180ms ease,
			color 180ms ease;
	}

	.project-action-appstore {
		min-height: 2.5rem;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
	}

	.project-action-appstore img {
		display: block;
		width: 7.5rem;
		height: 2.5rem;
	}

	.project-action:hover,
	.project-action:focus-visible {
		background: #111;
		color: #fff;
	}

	.project-action-appstore:hover,
	.project-action-appstore:focus-visible {
		background: transparent;
		color: inherit;
	}

	.project-action:only-child {
		margin-top: 0.25rem;
	}

	@media (max-width: 700px) {
		.projects-page {
			width: min(100% - 1.25rem, 76rem);
			padding-top: 1.25rem;
			padding-bottom: 3rem;
		}

		.project-sections {
			gap: 1rem;
		}

		.project-section {
			min-height: 28rem;
			padding: 3rem 1rem;
		}

		.project-image {
			width: min(62vw, 12rem);
		}
	}
</style>
