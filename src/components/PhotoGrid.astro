---
import PhotoModal from "./PhotoModal.astro";
import type { Photo } from "../lib/photos";

interface Props {
	photos: Photo[];
}

const { photos } = Astro.props;

function apertureLabel(value: string | number | null) {
	if (!value) {
		return null;
	}

	const text = String(value);

	return text.startsWith("f/") ? text : `f/${text}`;
}

function locationLabel(photo: Photo) {
	const parts = [photo.metadata.city, photo.metadata.country].filter(Boolean);

	return parts.length > 0 ? parts.join(", ") : null;
}

function metadataRows(photo: Photo) {
	const rows = [
		{ icon: "camera", label: "Camera", value: photo.camera },
		{ icon: "lens", label: "Lens", value: photo.metadata.lensModel },
		{ icon: "film", label: "Film", value: photo.film },
		{ icon: "date", label: "Date", value: photo.dateDisplay },
		{ icon: "location", label: "Location", value: locationLabel(photo) },
		{ icon: "shutter", label: "Shutter", value: photo.metadata.shutterSpeed },
		{ icon: "aperture", label: "Aperture", value: apertureLabel(photo.metadata.aperture) },
	];

	return rows
		.filter((row) => row.icon !== "location" || row.value)
		.map((row) => ({
			...row,
			value: row.value ? String(row.value) : "-",
		}));
}
---

<div class="photo-grid">
	{photos.map((photo, index) => (
		<figure class="photo">
			<button
				class="photo-button"
				type="button"
				aria-label={`View photo ${index + 1}`}
				data-large-url={photo.images.large.url}
				data-blur-url={photo.images.blur.url}
				data-large-width={photo.images.large.width ?? photo.images.grid.width}
				data-large-height={photo.images.large.height ?? photo.images.grid.height}
				data-properties={JSON.stringify(metadataRows(photo))}
			>
				<img src={photo.images.blur.url} 
					 alt=""
					 aria-hidden="true" />
				<img
					src={photo.images.grid.url}
					srcset={`${photo.images.thumb.url} 480w, ${photo.images.grid.url} 960w, ${photo.images.large.url} 2048w`}
					sizes="(max-width: 720px) 50vw, (max-width: 1200px) 33vw, 25vw"
					width={photo.images.grid.width ?? undefined}
					height={photo.images.grid.height ?? undefined}
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</button>
		</figure>
	))}
</div>

<PhotoModal />

<style>
	.photo-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.photo {
		margin: 0;
		min-width: 0;
	}

	.photo-button {
		display: grid;
		place-items: center;
		position: relative;
		width: 100%;
		aspect-ratio: 1;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		cursor: zoom-in;
		overflow: hidden;
	}

	.photo-button:focus-visible {
		outline: 2px solid #111;
		outline-offset: 4px;
	}

	.photo-button img {
		display: block;
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 42rem) {
		.photo-grid {
			grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
		}
	}
</style>
