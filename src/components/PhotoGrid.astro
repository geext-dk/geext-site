---
import PhotoModal from "./PhotoModal.astro";
import type { Photo } from "../lib/photos";

interface Props {
	photos: Photo[];
}

const { photos } = Astro.props;

function imageSizeLabel(width: number | null, height: number | null) {
	if (!width || !height) {
		return null;
	}

	return `${width} x ${height}`;
}

function apertureLabel(value: string | number | null) {
	if (!value) {
		return null;
	}

	const text = String(value);

	return text.startsWith("f/") ? text : `f/${text}`;
}

function metadataRows(photo: Photo) {
	const rows = [
		["Filename", photo.filename],
		["Roll", photo.roll],
		["Date", photo.dateDisplay],
		["Camera", photo.camera],
		["Film", photo.film],
		["Lens", photo.metadata.lensModel],
		["Focal length", photo.metadata.focalLength],
		["Aperture", apertureLabel(photo.metadata.aperture)],
		["Shutter", photo.metadata.shutterSpeed],
		["ISO", photo.metadata.iso ? String(photo.metadata.iso) : null],
		["Large image", imageSizeLabel(photo.images.large.width, photo.images.large.height)],
		[
			"Original image",
			photo.images.original
				? imageSizeLabel(photo.images.original.width, photo.images.original.height)
				: null,
		],
	];

	return rows
		.filter(([, value]) => value)
		.map(([label, value]) => ({ label, value }));
}
---

<div class="photo-grid">
	{photos.map((photo) => (
		<figure class="photo">
			<button
				class="photo-button"
				type="button"
				aria-label={`View ${photo.filename}`}
				data-large-url={photo.images.large.url}
				data-original-url={photo.images.original?.url ?? photo.images.large.url}
				data-filename={photo.filename}
				data-properties={JSON.stringify(metadataRows(photo))}
			>
				<img
					src={photo.images.grid.url}
					srcset={`${photo.images.thumb.url} 480w, ${photo.images.grid.url} 960w, ${photo.images.large.url} 2048w`}
					sizes="(max-width: 720px) 100vw, (max-width: 1200px) 50vw, 33vw"
					width={photo.images.grid.width ?? undefined}
					height={photo.images.grid.height ?? undefined}
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</button>
			<figcaption>
				<span>{photo.dateDisplay}</span>
				<span>{photo.camera}</span>
				<span>{photo.film}</span>
			</figcaption>
		</figure>
	))}
</div>

<PhotoModal />

<style>
	.photo-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
		gap: 2.25rem 1rem;
	}

	.photo {
		margin: 0;
		min-width: 0;
	}

	.photo-button {
		display: grid;
		place-items: center;
		position: relative;
		width: 100%;
		aspect-ratio: 1;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		cursor: zoom-in;
		overflow: hidden;
	}

	.photo-button:focus-visible {
		outline: 2px solid #111;
		outline-offset: 4px;
	}

	.photo-button img {
		display: block;
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	figcaption {
		display: grid;
		gap: 0.18rem;
		padding-top: 0.65rem;
		color: #333;
		font-size: 0.82rem;
		line-height: 1.35;
	}

	figcaption span:first-child {
		color: #666;
	}
</style>
