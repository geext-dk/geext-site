---
import {
	Aperture,
	Calendar,
	Camera,
	Film,
	LensConvex,
	Timer,
	X,
} from "@lucide/astro";

const iconProps = {
	size: 16,
	"stroke-width": 1.75,
};
---

<dialog class="photo-dialog" aria-label="Photo viewer">
	<div class="photo-viewer">
		<div class="viewer-content">
			<div class="viewer-image-frame">
				<div class="viewer-image-wrap">
					<img class="viewer-image image-placeholder" alt="" />
					<img class="viewer-image image-main" alt="" />
				</div>
			</div>
			<aside class="viewer-details">
				<div class="viewer-header">
					<button
						class="close-button"
						type="button"
						aria-label="Close"
					>
						<X {...iconProps} />
					</button>
				</div>
				<dl class="property-list"></dl>
			</aside>
		</div>
	</div>
	<div class="property-icon-templates" hidden>
		<template data-property-icon="date"
			><Calendar {...iconProps} /></template
		>
		<template data-property-icon="camera"
			><Camera {...iconProps} /></template
		>
		<template data-property-icon="film"><Film {...iconProps} /></template>
		<template data-property-icon="lens"
			><LensConvex {...iconProps} /></template
		>
		<template data-property-icon="aperture"
			><Aperture {...iconProps} /></template
		>
		<template data-property-icon="shutter"
			><Timer {...iconProps} /></template
		>
	</div>
</dialog>

<script>
	const dialog = document.querySelector(".photo-dialog");
	const viewerImage = dialog?.querySelector(".viewer-image.image-main");
	const viewerImagePlaceholder = dialog?.querySelector(".viewer-image.image-placeholder");
	const viewerContent = dialog?.querySelector(".viewer-content");
	const viewerDetails = dialog?.querySelector(".viewer-details");
	const viewerImageFrame = dialog?.querySelector(".viewer-image-frame");
	const propertyList = dialog?.querySelector(".property-list");
	const closeButton = dialog?.querySelector(".close-button");
	let isClosing = false;
	let isScrollLocked = false;
	let scrollY = 0;
	const stackedLayoutQuery = "(max-width: 760px)";
	const iconTemplates = new Map(
		[
			...(dialog?.querySelectorAll("template[data-property-icon]") ?? []),
		].map((template) => [template.dataset.propertyIcon, template]),
	);

	function propertyTerm(icon, label) {
		const term = document.createElement("dt");
		const template = iconTemplates.get(icon);

		term.className = "property-icon";
		term.title = label;

		if (template instanceof HTMLTemplateElement) {
			const iconNode = template.content.cloneNode(true);
			const svg = iconNode.firstElementChild;

			if (svg) {
				svg.setAttribute("aria-hidden", "true");
				svg.setAttribute("focusable", "false");
			}

			term.append(iconNode);
		} else {
			term.textContent = label;
		}

		const accessibleLabel = document.createElement("span");
		accessibleLabel.className = "visually-hidden";
		accessibleLabel.textContent = label;
		term.append(accessibleLabel);

		return term;
	}

	function setProperties(properties) {
		if (!propertyList) {
			return;
		}

		propertyList.replaceChildren(
			...properties.map(({ icon, label, value }) => {
				const property = document.createElement("div");
				const description = document.createElement("dd");

				property.className = "property";
				description.textContent = value || "-";
				property.append(propertyTerm(icon, label), description);

				return property;
			}),
		);
	}

	function syncViewerMeasurements() {
		if (
			!(dialog instanceof HTMLDialogElement) ||
			!(viewerImage instanceof HTMLImageElement) ||
			!(viewerDetails instanceof HTMLElement) ||
			!(viewerImageFrame instanceof HTMLElement)
		) {
			return;
		}

		const naturalWidth = Number(viewerImage.getAttribute("width"));
		const naturalHeight = Number(viewerImage.getAttribute("height"));

		if (!naturalWidth || !naturalHeight) {
			return;
		}

		setViewerMeasurementProperties(naturalWidth, naturalHeight);
	}

	function setViewerMeasurementProperties(width, height) {
		if (!(dialog instanceof HTMLDialogElement)) {
			return;
		}

		dialog.style.setProperty("--viewer-image-width", String(width));
		dialog.style.setProperty("--viewer-image-height", String(height));

		if (!dialog.open) {
			return;
		}

		syncViewerFrameSize(width, height);
	}

	function syncViewerFrameSize(width, height) {
		if (
			!(dialog instanceof HTMLDialogElement) ||
			!(viewerDetails instanceof HTMLElement) ||
			!(viewerImageFrame instanceof HTMLElement)
		) {
			return;
		}

		const dialogRect = dialog.getBoundingClientRect();
		const detailsRect = viewerDetails.getBoundingClientRect();
		const frameStyle = window.getComputedStyle(viewerImageFrame);
		const paddingX =
			Number.parseFloat(frameStyle.paddingLeft) +
			Number.parseFloat(frameStyle.paddingRight);
		const paddingY =
			Number.parseFloat(frameStyle.paddingTop) +
			Number.parseFloat(frameStyle.paddingBottom);
		const isStackedLayout =
			window.matchMedia(stackedLayoutQuery).matches || width >= height;
		const availableWidth = isStackedLayout
			? dialogRect.width
			: dialogRect.width - detailsRect.width;
		const availableHeight = isStackedLayout
			? dialogRect.height - detailsRect.height
			: dialogRect.height;
		const maxImageWidth = Math.max(0, availableWidth - paddingX);
		const maxImageHeight = Math.max(0, availableHeight - paddingY);
		const imageAspect = width / height;
		let imageWidth = maxImageWidth;
		let imageHeight = imageWidth / imageAspect;

		if (imageHeight > maxImageHeight) {
			imageHeight = maxImageHeight;
			imageWidth = imageHeight * imageAspect;
		}

		dialog.style.setProperty("--viewer-frame-width", `${imageWidth + paddingX}px`);
		dialog.style.setProperty("--viewer-frame-height", `${imageHeight + paddingY}px`);
	}

	function setViewerDimensions(width, height) {
		if (
			!(dialog instanceof HTMLDialogElement) ||
			!(viewerImage instanceof HTMLImageElement) ||
			!(viewerImagePlaceholder instanceof HTMLImageElement)
		) {
			return;
		}

		if (!width || !height) {
			return;
		}

		viewerImage.setAttribute("width", String(width));
		viewerImage.setAttribute("height", String(height));
		viewerImagePlaceholder.setAttribute("width", String(width));
		viewerImagePlaceholder.setAttribute("height", String(height));
		setViewerMeasurementProperties(width, height);
		dialog.dataset.orientation = height > width ? "portrait" : "landscape";
	}

	function cssImageUrl(url) {
		if (!url) {
			return "none";
		}

		return `url("${url.replaceAll("\\", "\\\\").replaceAll('"', '\\"')}")`;
	}

	function closeDialog() {
		if (
			!(dialog instanceof HTMLDialogElement) ||
			isClosing ||
			!dialog.open
		) {
			return;
		}

		isClosing = true;
		dialog.dataset.closing = "true";

		window.setTimeout(() => {
			dialog.close();
			isClosing = false;
			delete dialog.dataset.closing;
			unlockPageScroll();
		}, 180);
	}

	function lockPageScroll() {
		if (isScrollLocked) {
			return;
		}

		isScrollLocked = true;
		scrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${scrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
	}

	function unlockPageScroll() {
		if (!isScrollLocked) {
			return;
		}

		isScrollLocked = false;
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		window.scrollTo(0, scrollY);
	}

	dialog?.addEventListener("close", () => {
		isClosing = false;
		delete dialog.dataset.closing;
		unlockPageScroll();
	});

	closeButton?.addEventListener("click", (event) => {
		event.stopPropagation();
		closeDialog();
	});

	document.querySelectorAll(".photo-button").forEach((button) => {
		button.addEventListener("click", () => {
			if (
				!(dialog instanceof HTMLDialogElement) ||
				!(viewerImage instanceof HTMLImageElement) ||
				!(viewerImagePlaceholder instanceof HTMLImageElement)
			) {
				return;
			}

			const properties = JSON.parse(button.dataset.properties ?? "[]");
			const imageWidth = Number(button.dataset.largeWidth);
			const imageHeight = Number(button.dataset.largeHeight);

			delete dialog.dataset.orientation;
			dialog.style.removeProperty("--viewer-image-width");
			dialog.style.removeProperty("--viewer-image-height");
			dialog.style.removeProperty("--viewer-frame-width");
			dialog.style.removeProperty("--viewer-frame-height");
			dialog.style.removeProperty("--viewer-placeholder-image");
			setProperties(properties);
			setViewerDimensions(imageWidth, imageHeight);
			viewerImage.src = button.dataset.largeUrl ?? "";
			viewerImage.alt = "";
			viewerImagePlaceholder.removeAttribute("src");
			dialog.style.setProperty(
				"--viewer-placeholder-image",
				cssImageUrl(button.dataset.blurUrl ?? ""),
			);

			lockPageScroll();
			dialog.showModal();
			syncViewerMeasurements();
		});
	});

	window.addEventListener("resize", syncViewerMeasurements);

	dialog?.addEventListener("click", (event) => {
		if (
			dialog instanceof HTMLDialogElement &&
			viewerContent instanceof HTMLElement &&
			event.target instanceof Node &&
			!viewerContent.contains(event.target)
		) {
			closeDialog();
		}
	});

	dialog?.addEventListener("cancel", (event) => {
		event.preventDefault();
		closeDialog();
	});
</script>

<style>
	.photo-dialog {
		--viewer-image-height: 1;
		--viewer-image-width: 1;
		--viewer-frame-width: auto;
		--viewer-frame-height: auto;
		--viewer-placeholder-image: none;
		width: min(100% - 2rem, 86rem);
		max-width: none;
		height: min(100% - 2rem, 52rem);
		max-height: none;
		padding: 0;
		border: 0;
		background: transparent;
		color: #fbfaf6;
		opacity: 0;
		transform: scale(0.96);
	}

	.photo-dialog[open] {
		animation: modal-enter 180ms ease-out forwards;
	}

	.photo-dialog[data-closing="true"] {
		animation: modal-exit 160ms ease-in forwards;
	}

	.photo-dialog::backdrop {
		background: rgb(0 0 0 / 0.72);
		animation: backdrop-enter 180ms ease-out forwards;
	}

	.photo-dialog[data-closing="true"]::backdrop {
		animation: backdrop-exit 160ms ease-in forwards;
	}

	.photo-viewer {
		display: grid;
		place-items: center;
		width: 100%;
		height: 100%;
	}

	.viewer-content {
		display: grid;
		grid-template-rows: minmax(0, 1fr) auto;
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		min-width: 0;
		min-height: 0;
	}

	.viewer-image-frame {
		display: grid;
		place-items: center;
		place-self: center;
		width: var(--viewer-frame-width);
		height: var(--viewer-frame-height);
		max-width: 100%;
		max-height: 100%;
		min-width: 0;
		min-height: 0;
		padding: 1.5rem;
		background: white;
	}

	.viewer-image-wrap {
		display: grid;
		place-items: center;
		justify-content: center;
		position: relative;
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		min-height: 0;
		min-width: 0;
		overflow: hidden;
		background-image: var(--viewer-placeholder-image);
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		aspect-ratio: calc(var(--viewer-image-width) / var(--viewer-image-height));
	}

	.viewer-image {
		grid-area: 1/1;
		display: block;
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		object-position: center;
		aspect-ratio: calc(var(--viewer-image-width) / var(--viewer-image-height));
	}

	.viewer-image.image-placeholder {
		display: none;
	}

	.viewer-details {
		display: grid;
		grid-template-rows: auto;
		gap: 1rem;
		width: auto;
		min-width: 0;
		padding: 1.25rem;
		overflow: auto;
		background: #0b0b0b;
		color: #fbfaf6;
	}

	.viewer-header {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1rem;
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 1;
	}

	.close-button {
		display: grid;
		width: 2rem;
		height: 2rem;
		place-items: center;
		padding: 0;
		border: 0;
		background: rgb(11 11 11 / 0.55);
		color: #fbfaf6;
		cursor: pointer;
		font: inherit;
		line-height: 1;
	}

	.close-button:focus-visible {
		outline: 2px solid #fbfaf6;
		outline-offset: 3px;
	}

	.property-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem 1rem;
		align-content: start;
		width: 100%;
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.45;
	}

	:global(.property) {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: center;
		gap: 0.45rem;
		min-width: 0;
	}

	.property-list :global(dt) {
		color: #fbfaf6;
	}

	:global(.property-icon) {
		display: grid;
		width: 1.35rem;
		height: 1.35rem;
		place-items: center;
	}

	:global(.property-icon svg) {
		width: 1rem;
		height: 1rem;
	}

	.property-list :global(dd) {
		margin: 0;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	.photo-dialog[data-orientation="portrait"] .photo-viewer {
		place-items: center;
	}

	.photo-dialog[data-orientation="portrait"] .viewer-content {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
	}

	.photo-dialog[data-orientation="portrait"] .viewer-details {
		width: auto;
		height: 100%;
		max-height: 100%;
	}

	.photo-dialog[data-orientation="portrait"] .viewer-image-frame {
		flex: 0 0 auto;
		width: var(--viewer-frame-width);
		height: var(--viewer-frame-height);
		max-width: 100%;
		max-height: 100%;
	}

	.photo-dialog[data-orientation="portrait"] .property-list {
		grid-template-columns: 1fr;
	}

	:global(.visually-hidden) {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 980px) {
		.viewer-details {
			max-height: 42vh;
		}

		.property-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.photo-dialog[data-orientation="portrait"] .viewer-content {
			width: 100%;
		}

		.photo-dialog[data-orientation="portrait"] .viewer-details {
			max-height: 100%;
		}

		.photo-dialog[data-orientation="portrait"] .property-list {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 760px) {
		.photo-dialog {
			width: 100vw;
			height: 100dvh;
			margin: 0;
		}

		.photo-dialog[data-orientation="portrait"] .viewer-content,
		.viewer-content {
			display: grid;
			grid-template-rows: minmax(0, 1fr) auto;
			align-items: stretch;
			justify-content: normal;
			width: 100%;
			height: 100%;
		}

		.viewer-image-frame {
			padding: 1rem;
		}

		.photo-dialog[data-orientation="portrait"] .viewer-image-frame {
			flex: 0 0 auto;
		}

		.photo-dialog[data-orientation="portrait"] .viewer-image-wrap,
		.viewer-image-wrap {
			width: 100%;
		}

		.photo-dialog[data-orientation="portrait"] .viewer-details,
		.viewer-details {
			align-self: auto;
			justify-self: stretch;
			width: auto;
			height: auto;
			max-height: 42dvh;
		}

		.photo-dialog[data-orientation="portrait"] .property-list,
		.property-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@keyframes modal-enter {
		from {
			opacity: 0;
			transform: scale(0.96);
		}

		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	@keyframes modal-exit {
		from {
			opacity: 1;
			transform: scale(1);
		}

		to {
			opacity: 0;
			transform: scale(0.96);
		}
	}

	@keyframes backdrop-enter {
		from {
			background: rgb(0 0 0 / 0);
		}

		to {
			background: rgb(0 0 0 / 0.72);
		}
	}

	@keyframes backdrop-exit {
		from {
			background: rgb(0 0 0 / 0.72);
		}

		to {
			background: rgb(0 0 0 / 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.photo-dialog[open],
		.photo-dialog[data-closing="true"],
		.photo-dialog::backdrop,
		.photo-dialog[data-closing="true"]::backdrop {
			animation-duration: 1ms;
		}
	}
</style>
